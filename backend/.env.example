# Copy to .env locally (never commit .env).

# Primary Postgres URL (direct or pooler — see below)
DATABASE_URL=

# Optional: Supabase Transaction pooler URI (recommended on Render).
# Dashboard → Project Settings → Database → Connection string → Transaction pooler (port 6543).
# If set, this overrides DATABASE_URL.
DATABASE_POOLER_URL=
# Alias also supported:
# SUPABASE_POOLER_URL=

# Clerk (backend verifies JWTs)
CLERK_JWKS_URL=
# Optional strict issuer check
CLERK_JWT_ISSUER=
# Backend API key — required for movement alert emails (lookup user email)
CLERK_SECRET_KEY=

# CORS: comma-separated frontend origins, e.g. https://your-app.vercel.app
CORS_ORIGINS=

# LLM / analysis keys (set whatever your deployment uses)
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# Four main engines for prompt analysis (default order):
# RANKLORE_ENGINE_ORDER=chatgpt,gemini,perplexity,claude
# etc.

# Native web search inside each LLM (all default to true when the key is set).
# These make each model fetch live sources itself and return citations, so the
# external Serper/Perplexity search layer is only needed as a fallback.
# OPENAI_ENABLE_WEB_SEARCH=true          # ChatGPT web_search tool (Responses API)
# GEMINI_ENABLE_WEB_SEARCH=true          # Gemini google_search grounding
# CLAUDE_ENABLE_WEB_SEARCH=true          # Claude server-side web_search tool
# CLAUDE_WEB_SEARCH_TOOL_VERSION=web_search_20250305
# CLAUDE_WEB_SEARCH_MAX_USES=3
# PERPLEXITY_ENABLE_WEB_SEARCH=true      # Perplexity sonar (always searches)

# Optional: external web search source layer (fallback only — used when no LLM
# returned citations for a prompt, to keep the Sources section populated).
# Preferred provider if configured:
#   serper (Google via serper.dev) -> perplexity fallback
RANKLORE_SEARCH_PROVIDER=serper
# Accepts either SERPER_API_KEY or GOOGLE_SEARCH_API_KEY.
SERPER_API_KEY=
# GOOGLE_SEARCH_API_KEY=
SERPER_SEARCH_URL=https://google.serper.dev/search
WEB_SEARCH_TIMEOUT_SECONDS=20

# Keep visibility measurement on raw LLM answers by default. Enable this only
# for an explicitly search-grounded experiment, not the main visibility score.
RANKLORE_SEARCH_AUGMENT_ENABLED=false
RANKLORE_SEARCH_AUGMENT_MAX_RESULTS=5
RANKLORE_SEARCH_AUGMENT_SNIPPET_CHARS=200
# Keep synthetic prompt variants out of measured visibility by default.
RANKLORE_MEASURE_PROMPT_VARIANTS=false

# Cashfree (sandbox first): Developers -> API Keys + Webhooks -> https://your-api/api/billing/webhook
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_WEBHOOK_SECRET=
CASHFREE_ENVIRONMENT=sandbox
CASHFREE_API_VERSION=2025-01-01
FRONTEND_URL=http://localhost:5173
# Public backend URL for Cashfree return redirect (required in production)
# API_PUBLIC_URL=https://your-api.onrender.com
# Billing currency: USD (card only) or INR (UPI, card, net banking, wallet)
CASHFREE_PLAN_CURRENCY=USD
# Production monthly one-time order amounts. Override in Render if pricing changes.
CASHFREE_PLAN_STANDARD_AMOUNT=79
CASHFREE_PLAN_PRO_AMOUNT=149

# Landing page - "Request demo" form (sent to hello@answrdeck.com)
DEMO_REQUEST_TO_EMAIL=hello@answrdeck.com
# Option A: Resend (https://resend.com) - recommended
RESEND_API_KEY=
RESEND_FROM_EMAIL=Answrdeck <onboarding@resend.dev>
# Option B: SMTP (Gmail, SendGrid SMTP, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
# Dev: log demo requests when no mail provider is configured (FLASK_DEBUG=true also enables this)
DEMO_REQUEST_DEV_LOG=true

# Movement alerts — email when AI visibility changes between runs
MOVEMENT_ALERTS_ENABLED=true
# Dev: log alert payloads when mail is not configured
MOVEMENT_ALERTS_DEV_LOG=true
