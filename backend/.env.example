# Copy to .env locally (never commit .env).

# Primary Postgres URL (direct or pooler — see below)
DATABASE_URL=

# Optional: Supabase Transaction pooler URI (recommended on Render).
# Dashboard → Project Settings → Database → Connection string → Transaction pooler (port 6543).
# If set, this overrides DATABASE_URL.
DATABASE_POOLER_URL=
# Alias also supported:
# SUPABASE_POOLER_URL=

# Clerk (backend verifies JWTs)
CLERK_JWKS_URL=
# Optional strict issuer check
CLERK_JWT_ISSUER=

# CORS: comma-separated frontend origins, e.g. https://your-app.vercel.app
CORS_ORIGINS=

# LLM / analysis keys (set whatever your deployment uses)
# OPENAI_API_KEY=
# etc.
