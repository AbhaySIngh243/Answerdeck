# Copy to .env for local dev. On Vercel: Project → Settings → Environment Variables
# (use Production + Preview). Vite bakes VITE_* in at build time — redeploy after changes.

# Public API base, must include /api (e.g. https://your-api.onrender.com/api)
VITE_API_BASE_URL=

# Clerk Dashboard → API Keys → Publishable key
VITE_CLERK_PUBLISHABLE_KEY=

# Cashfree checkout mode: sandbox | production (must match backend CASHFREE_ENVIRONMENT)
VITE_CASHFREE_MODE=sandbox

# Optional: client fetch timeouts (ms)
# VITE_API_TIMEOUT_MS=60000
# VITE_API_LONG_TIMEOUT_MS=180000
